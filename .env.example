# Application
APP_APP_NAME=Dealer Hygiene Compliance Backend
APP_DEBUG=false
APP_ENVIRONMENT=development

# PostgreSQL
APP_POSTGRES_HOST=localhost
APP_POSTGRES_PORT=5432
APP_POSTGRES_DB=audit_db
APP_POSTGRES_USER=postgres
APP_POSTGRES_PASSWORD=changeme

# JWT
APP_JWT_SECRET_KEY=change-me-in-production-use-long-secret
APP_JWT_ALGORITHM=HS256
APP_JWT_ACCESS_EXPIRE_MINUTES=60
APP_JWT_REFRESH_EXPIRE_DAYS=7

# Storage (local path for uploads)
APP_STORAGE_PATH=./uploads

# CORS (comma-separated origins, or * for all)
APP_CORS_ORIGINS=*
