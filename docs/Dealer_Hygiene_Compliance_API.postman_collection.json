{
	"info": {
		"_postman_id": "audit-backend-v1",
		"name": "Dealer Hygiene Compliance API",
		"description": "Dealer Hygiene Compliance API. All roles login via POST /auth/login. Run Login first to set access_token. Set country_id for Stellantis Admin; zone_id for Dealerships; facility_id for Employees and Audits.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{ "key": "token", "value": "{{access_token}}", "type": "string" }
		]
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000" },
		{ "key": "access_token", "value": "" },
		{ "key": "refresh_token", "value": "" },
		{ "key": "zone_id", "value": "" },
		{ "key": "country_id", "value": "" },
		{ "key": "facility_id", "value": "" },
		{ "key": "category_id", "value": "" },
		{ "key": "subcategory_id", "value": "" },
		{ "key": "audit_id", "value": "" },
		{ "key": "user_id", "value": "" },
		{ "key": "employee_id", "value": "" },
		{ "key": "checkpoint_id", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token || '');",
									"    console.log('[OK] Token saved');",
									"} else {",
									"    console.log('[ERROR] Login failed:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
						},
						"url": "{{base_url}}/auth/login",
						"description": "Login with email and password (same endpoint for all roles). Saves access_token and refresh_token. Run this first."
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token || '');",
									"    console.log('[OK] Token refreshed');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
						},
						"url": "{{base_url}}/auth/refresh",
						"description": "Uses refresh_token; updates access_token and refresh_token."
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/logout"
					}
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/auth/me"
					}
				}
			]
		},
